# IOTA mobile web / Web FCM environment sample
# Fill these values outside Git. Do not commit a real .env file.

# Supabase client config
# Existing main web platform likely already has these.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Firebase Web app config
# Firebase Console > Project settings > General > Your apps > Web app > SDK setup and configuration > Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Web Push certificate
# Firebase Console > Project settings > Cloud Messaging > Web configuration > Web Push certificates
VITE_FIREBASE_VAPID_KEY=

# Optional: public mobile route used by notification click handlers.
# Example: /mobile
VITE_IOTA_MOBILE_ROUTE=/mobile
